rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isRoomMember(roomId) {
      return exists(/databases/$(database)/documents/chatRoomMembers/$(roomId + '_' + request.auth.uid))
          || get(/databases/$(database)/documents/chatRoomMembers/$(roomId + '_' + request.auth.uid)) != null;
    }

    function isChatParticipant(chatData) {
      return chatData.user1Id == request.auth.uid
          || chatData.user2Id == request.auth.uid;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if false;
    }

    // ── chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (resource.data.user1Id == request.auth.uid
         || resource.data.user2Id == request.auth.uid);
      allow create: if isSignedIn()
        && (request.resource.data.user1Id == request.auth.uid
         || request.resource.data.user2Id == request.auth.uid);
      allow update: if isSignedIn()
        && (resource.data.user1Id == request.auth.uid
         || resource.data.user2Id == request.auth.uid);
      allow delete: if false;
    }

    // ── messages ──────────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;

      // Sender can update anything on their own messages (delete for everyone).
      // Any authenticated user can append their own UID to deletedFor (delete for me).
      // Any authenticated user can update readBy (read receipts).
      // Room owner/admin can soft-delete any message in their room.
      allow update: if isSignedIn()
        && (
          resource.data.senderId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor'])
          || (
            resource.data.roomId != null
            && get(/databases/$(database)/documents/chatRooms/$(resource.data.roomId)).data.ownerId == request.auth.uid
          )
        );

      allow delete: if isSignedIn()
        && resource.data.senderId == request.auth.uid;
    }

    // ── typing indicators ─────────────────────────────────────────────────────
    match /typing/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn();
    }

    // ── chatRooms ─────────────────────────────────────────────────────────────
    match /chatRooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // ── chatRoomMembers ───────────────────────────────────────────────────────
    match /chatRoomMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if false;
    }
  }
}
